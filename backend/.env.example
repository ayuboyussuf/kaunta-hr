# ── Kaunta-HR Backend — real credentials required (no mock mode) ──────────────

# Server
PORT=4000
NODE_ENV=development
# Comma-separated allowed origins (the frontend)
FRONTEND_URL=http://localhost:3000
# Public base URL of THIS backend (used in webhook + QR deep links)
BACKEND_URL=http://localhost:4000
# Public base URL of the frontend app (QR deep-links land here)
APP_URL=http://localhost:3000

# Supabase (same project shared with the frontend)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# Secrets for our own signed tokens
# QR workplace tokens (signed, long-lived ~3 months)
QR_TOKEN_SECRET=
# Employee session JWTs issued after OTP/PIN login
EMPLOYEE_JWT_SECRET=
# Protects cron endpoints (sent as x-cron-secret header)
CRON_SECRET=

# ── Africa's Talking SMS ──────────────────────────────────────────────────────
# All messaging (OTP, employee invites, announcements, and PDF download links)
# goes through Africa's Talking. https://account.africastalking.com
# Sandbox (free testing): AT_USERNAME=sandbox. Live: your real username + funded account.
AT_USERNAME=sandbox
AT_API_KEY=
# Optional branded alphanumeric sender id (needs AT approval). Blank = shared shortcode.
AT_SENDER_ID=
