# ── Kaunta-HR Frontend ────────────────────────────────────────────────────────
# Supabase (same project as the backend)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service key is used only by server components/actions that need to bypass RLS.
SUPABASE_SERVICE_KEY=

# Base URL of the Express backend (Render in prod, localhost in dev)
NEXT_PUBLIC_BACKEND_URL=http://localhost:4000
