# ── Kaunta-HR Frontend ────────────────────────────────────────────────────────
# Supabase (same project as the backend)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service key is used only by server components/actions that need to bypass RLS.
SUPABASE_SERVICE_KEY=

# Base URL of the Express backend (Render in prod, localhost in dev).
# The browser no longer calls this directly — requests go through the same-origin
# /gateway proxy — so set BACKEND_URL (a server-only runtime var, no rebuild
# needed). NEXT_PUBLIC_BACKEND_URL is still read as a fallback for compatibility.
BACKEND_URL=http://localhost:4000
NEXT_PUBLIC_BACKEND_URL=http://localhost:4000
